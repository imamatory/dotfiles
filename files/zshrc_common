# The next line updates PATH for CLI.
if [ -f '/Users/im/yandex-cloud/path.bash.inc' ]; then source '/Users/im/yandex-cloud/path.bash.inc'; fi

# The next line enables shell command completion for yc.
if [ -f '/Users/im/yandex-cloud/completion.zsh.inc' ]; then source '/Users/im/yandex-cloud/completion.zsh.inc'; fi

# The following lines have been added by Docker Desktop to enable Docker CLI completions.
fpath=(/Users/im/.docker/completions $fpath)
autoload -Uz compinit
